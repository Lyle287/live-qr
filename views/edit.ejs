<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>编辑活码 - <%= code.name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="header-inner">
      <h1>📱 编辑活码</h1>
      <a href="/" class="back-link">← 返回后台</a>
    </div>
  </header>
  <main>
    <div class="form-card">
      <form action="/edit/<%= code.id %>" method="POST">
        <div class="form-group">
          <label for="name">活码名称</label>
          <input type="text" id="name" name="name" value="<%= code.name %>" required>
        </div>
        <div class="form-group">
          <label for="targetUrl">跳转链接</label>
          <input type="url" id="targetUrl" name="targetUrl" value="<%= code.targetUrl %>" required>
          <p class="form-hint">修改此项后，该活码的二维码图案<strong>无需变更</strong></p>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-lg">保存修改</button>
          <a href="/" class="btn btn-secondary btn-lg">取消</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
